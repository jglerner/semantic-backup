#!/bin/bash
set -euo pipefail

COMMAND=${1:-run}

########################################
# HARDENED ENVIRONMENT
########################################

export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

########################################
# CONFIGURATION
########################################

RETENTION_DAYS=7

SOURCE="/home/jglerner"
INCLUDE_FILE="/home/jglerner/infra/engine/include.txt"
LOG_FILE="/var/log/semantic-backup.log"

LOCAL_BASE="/var/lib/semantic-backup/snapshots"

MOUNT_POINT="/mnt/semantic_backup"
UUID="f0e81617-0984-4bfc-bc9e-e01624dac735"
EXTERNAL_BASE="$MOUNT_POINT/snapshots"

    echo
    echo "Latest snapshot preview:"
    LATEST=$(ls -1 "$LOCAL_BASE" | sort | tail -n 1)

    if [ -n "$LATEST" ]; then
        ls "$LOCAL_BASE/$LATEST" | head
    fi
TODAY=$(date +%Y%m%d)
LOCAL_TODAY="$LOCAL_BASE/$TODAY"

case "$COMMAND" in
    run)
        ;;
status)
        systemctl status semantic-backup.service
        exit 0
        ;;

verify)
    echo "======================================="
    echo " Snapshot verification"
    echo "======================================="

    if [ ! -d "$LOCAL_BASE" ]; then
        echo "ERROR: Snapshot directory missing."
        exit 1
    fi

    echo "Available snapshots:"
    ls -1 "$LOCAL_BASE"

    echo
    echo "Disk usage:"
    du -sh "$LOCAL_BASE"/* 2>/dev/null || true

    echo
    echo "Latest snapshot preview:"
    LATEST=$(ls -1 "$LOCAL_BASE" | sort | tail -n 1)

    if [ -n "$LATEST" ]; then
        ls "$LOCAL_BASE/$LATEST" | head
    fi

    echo
    echo "Verification complete."
    exit 0
    ;;

restore)
    SNAPSHOT=${2:-}

    if [ -z "$SNAPSHOT" ]; then
        echo "Usage: semantic-backup restore YYYYMMDD"
        exit 1
    fi

    SNAPSHOT_PATH="$LOCAL_BASE/$SNAPSHOT"

    if [ ! -d "$SNAPSHOT_PATH" ]; then
        echo "Snapshot not found: $SNAPSHOT"
        exit 1
    fi

    echo "Restoring snapshot $SNAPSHOT..."
    rsync -a --delete "$SNAPSHOT_PATH/" "$SOURCE/"

    echo "Restore complete."
    exit 0
    ;;

esac

########################################
# FUNCTIONS
########################################

send_failure_mail() {
    echo "Semantic backup FAILED on $(hostname) at $(date)" \
        | mail -s "Backup FAILED" jglerner@gmail.com
}

cleanup_mount() {
    if mountpoint -q "$MOUNT_POINT"; then
        echo "Cleaning up mount..."
        cd /
        sync
        umount "$MOUNT_POINT" || true
    fi
}

log() {
    echo "$(date '+%F %T') $*" | tee -a "$LOG_FILE"
}

trap cleanup_mount EXIT

########################################
# START
########################################

echo "======================================="
echo " Semantic Backup $(date)"
echo "======================================="

########################################
# LOCAL SNAPSHOT
########################################

mkdir -p "$LOCAL_BASE"

if [ -d "$LOCAL_TODAY" ]; then
    echo "Snapshot for today already exists."
else
    PREVIOUS=$(ls -1 "$LOCAL_BASE" 2>/dev/null | sort | tail -n 1 || true)

    if [ -n "$PREVIOUS" ] && [ -d "$LOCAL_BASE/$PREVIOUS" ]; then
        echo "Using previous snapshot: $PREVIOUS"
        LINK_DEST="--link-dest=$LOCAL_BASE/$PREVIOUS"
    else
        echo "No previous snapshot found. Creating full snapshot."
        LINK_DEST=""
    fi

    log "Creating local snapshot..."

    rsync -aHAX --delete \
        $LINK_DEST \
        --files-from="$INCLUDE_FILE" \
        "$SOURCE/" \
        "$LOCAL_TODAY"

    echo "Local snapshot complete."
fi

echo "Applying local retention policy..."

find "$LOCAL_BASE" -mindepth 1 -maxdepth 1 -type d -mtime +$RETENTION_DAYS -exec rm -rf {} +

########################################
# EXTERNAL SYNC
########################################

echo "Mounting external drive..."

if ! mount UUID="$UUID" "$MOUNT_POINT"; then
    echo "External drive not available. Skipping external sync."
    exit 0
fi

echo "External drive mounted."

mkdir -p "$EXTERNAL_BASE"

echo "Syncing snapshot to external..."

rsync -a --delete --checksum \
    "$LOCAL_TODAY" \
    "$EXTERNAL_BASE/"

echo "External sync complete."

echo "Applying external retention policy..."
find "$EXTERNAL_BASE" -mindepth 1 -maxdepth 1 -type d -mtime +$RETENTION_DAYS -exec rm -rf {} +

echo "Flushing filesystem buffers..."
sync

cd /

echo "Unmounting external drive..."
umount "$MOUNT_POINT"

echo "External drive safely unmounted."

echo "======================================="
echo " Backup Completed Successfully"
echo "======================================="

exit 0
